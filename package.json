{
  "name": "pr-sks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/with-env.mjs dev -- next dev",
    "dev:uat": "node scripts/with-env.mjs uat -- next dev",
    "build": "prisma generate && next build",
    "build:dev": "node scripts/with-env.mjs dev -- npm run build",
    "build:uat": "node scripts/with-env.mjs uat -- npm run build",
    "build:prod": "node scripts/with-env.mjs prod -- npm run build",
    "start": "next start",
    "start:uat": "node scripts/with-env.mjs uat -- npm run start",
    "start:prod": "node scripts/with-env.mjs prod -- npm run start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "e2e:prepare": "prisma db push --accept-data-loss && npm run db:seed",
    "e2e:dev": "npm run e2e:prepare && next dev --hostname 127.0.0.1 --port 3100",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:dev": "node scripts/with-env.mjs dev -- npm run db:migrate",
    "db:deploy": "prisma migrate deploy",
    "db:deploy:uat": "node scripts/with-env.mjs uat -- npm run db:deploy",
    "db:deploy:prod": "node scripts/with-env.mjs prod -- npm run db:deploy",
    "db:seed": "prisma db seed",
    "db:seed:dev": "node scripts/with-env.mjs dev -- npm run db:seed",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@fontsource/noto-sans-thai": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.21.0",
    "next": "^15.5.19",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pg": "^8.22.0",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.79.0",
    "recharts": "^3.8.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.5.19",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
